<Window x:Class="TWLH_Loan_Management_System.PromiseForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TWLH_Loan_Management_System"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="Add Promise to Pay" Height="500" Width="450" 
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <!-- Modern Input Style -->
        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Elegant DatePicker Style -->
        <Style x:Key="ElegantDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" BorderThickness="1" BorderBrush="#E2E8F0" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#FFF2F6FF" Padding="30,25" BorderThickness="0,0,0,1" CornerRadius="20,20,0,0">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Add Promise to Pay" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Record a client's promise to pay." FontSize="13" Foreground="#64748B" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnCancel_Click">
                        <fa:ImageAwesome Icon="Close" Width="14" Height="14" Foreground="#64748B"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30,25">
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Promise Amount" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtAmount" Style="{StaticResource ModernInput}" Width="200" HorizontalAlignment="Left">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Payment Date" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                        <DatePicker x:Name="dpDate" Style="{StaticResource ElegantDatePicker}" Width="200" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Remarks / Notes" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtRemarks" Style="{StaticResource ModernInput}" Height="Auto" MinHeight="100" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="10">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#FFF2F6FF" Padding="30,20" BorderThickness="0,1,0,0" CornerRadius="0,0,20,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="Cancel" Grid.Column="0" Height="45" Margin="0,0,10,0" Background="White" Foreground="#64748B" BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand" Click="btnCancel_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnSave" Content="Save Record" Grid.Column="1" Height="45" Background="#3044FF" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="btnSave_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

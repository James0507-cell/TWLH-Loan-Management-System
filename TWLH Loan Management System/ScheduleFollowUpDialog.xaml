<Window x:Class="TWLH_Loan_Management_System.ScheduleFollowUpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="Schedule Follow-up" Height="400" Width="420" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Custom ScrollBar Style for a cleaner look -->
        <Style x:Key="TimePickerButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimeInputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,-30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="5"/>
        </Border.Effect>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Set Reminder" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Choose the exact moment for your follow-up." FontSize="14" Foreground="#64748B" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Inputs -->
            <StackPanel Grid.Row="1">
                <!-- Date Selector -->
                <TextBlock Text="DATE" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                <Border Background="#F8FAFC" CornerRadius="10" Padding="10,5" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <fa:ImageAwesome Icon="Calendar" Width="14" Foreground="#64748B" Margin="5,0,10,0"/>
                        <DatePicker x:Name="dpDate" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Height="35"/>
                    </Grid>
                </Border>

                <!-- Time Selector -->
                <TextBlock Text="TIME" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    
                    <!-- Hour Component -->
                    <StackPanel>
                        <Button Style="{StaticResource TimePickerButton}" Click="btnHourUp_Click">
                            <fa:ImageAwesome Icon="ChevronUp" Width="10" Foreground="#64748B"/>
                        </Button>
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Margin="0,2">
                            <TextBox x:Name="txtHour" Style="{StaticResource TimeInputStyle}" Text="09" PreviewTextInput="Time_PreviewTextInput"/>
                        </Border>
                        <Button Style="{StaticResource TimePickerButton}" Click="btnHourDown_Click">
                            <fa:ImageAwesome Icon="ChevronDown" Width="10" Foreground="#64748B"/>
                        </Button>
                    </StackPanel>

                    <TextBlock Text=":" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0" Foreground="#CBD5E1"/>

                    <!-- Minute Component -->
                    <StackPanel>
                        <Button Style="{StaticResource TimePickerButton}" Click="btnMinUp_Click">
                            <fa:ImageAwesome Icon="ChevronUp" Width="10" Foreground="#64748B"/>
                        </Button>
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Margin="0,2">
                            <TextBox x:Name="txtMin" Style="{StaticResource TimeInputStyle}" Text="00" PreviewTextInput="Time_PreviewTextInput"/>
                        </Border>
                        <Button Style="{StaticResource TimePickerButton}" Click="btnMinDown_Click">
                            <fa:ImageAwesome Icon="ChevronDown" Width="10" Foreground="#64748B"/>
                        </Button>
                    </StackPanel>

                    <!-- AM/PM Component -->
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="5">
                            <StackPanel>
                                <RadioButton x:Name="rbAM" GroupName="AMPM" IsChecked="True" Content="AM" FontSize="14" FontWeight="Bold" Margin="5"/>
                                <RadioButton x:Name="rbPM" GroupName="AMPM" Content="PM" FontSize="14" FontWeight="Bold" Margin="5"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="3" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Back" Grid.Column="0" Margin="0,0,10,0" Height="45" Background="Transparent" Foreground="#64748B" BorderBrush="#E2E8F0" BorderThickness="1" Click="btnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Schedule Event" Grid.Column="1" Height="45" Background="#4F46E5" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Click="btnConfirm_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>

<Window x:Class="TWLH_Loan_Management_System.addEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add New Employee" Height="600" Width="650"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="15" BorderThickness="1" BorderBrush="#E2E8F0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F8FAFC" Padding="25,20" CornerRadius="15,15,0,0" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                <StackPanel>
                    <TextBlock Text="New Employee Registration" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Fill in the details to create a new user account." Foreground="#64748B" FontSize="12"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="First Name" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtFirstName" Style="{StaticResource ModernInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="Last Name" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtLastName" Style="{StaticResource ModernInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Middle Name" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtMiddleName" Style="{StaticResource ModernInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="Gender" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="cmbGender" Style="{StaticResource ModernInput}" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Male"/>
                            <ComboBoxItem Content="Female"/>
                            <ComboBoxItem Content="Others"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Date of Birth" Style="{StaticResource LabelStyle}"/>
                        <DatePicker x:Name="dpBirthDate" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="System Role" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="cmbRole" Style="{StaticResource ModernInput}" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Admin"/>
                            <ComboBoxItem Content="Staff"/>
                            <ComboBoxItem Content="Loan Collector"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Contact Number" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtContact" Style="{StaticResource ModernInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="Email Address" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtEmail" Style="{StaticResource ModernInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,15">
                        <TextBlock Text="Assign Username" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource ModernInput}"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#F8FAFC" Padding="25,15" CornerRadius="0,0,15,15" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="btnCancel_Click" Width="100" Height="40" Background="Transparent" BorderBrush="#CBD5E1" Margin="0,0,10,0" Cursor="Hand"/>
                    <Button x:Name="btnSave" Content="Save Employee" Click="btnSave_Click" Width="140" Height="40" Background="#4F46E5" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
<Window x:Class="TWLH_Loan_Management_System.LoanForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TWLH_Loan_Management_System"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="Loan Form" Height="650" Width="480" 
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <!-- Modern Input Style -->
        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Elegant ComboBox Style (Fixed Dropdown) -->
        <Style x:Key="ElegantComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10"/>
                            
                            <!-- Main Toggle Button -->
                            <ToggleButton x:Name="toggleButton" BorderThickness="0" Background="Transparent" ClickMode="Press" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0 Z" Fill="#64748B" HorizontalAlignment="Right" Margin="0,0,15,0" VerticalAlignment="Center" Stretch="Uniform" Width="10"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Selection Display -->
                            <ContentPresenter x:Name="contentPresenter" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" IsHitTestVisible="false"/>
                            
                            <!-- Search/Edit Box -->
                            <TextBox x:Name="PART_EditableTextBox" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Padding="{TemplateBinding Padding}" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" FontSize="{TemplateBinding FontSize}"/>

                            <!-- Dropdown Popup -->
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Grid.ColumnSpan="2" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{Binding ActualWidth, ElementName=border}" Margin="0,2,0,0">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E0"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="true">
                                <Setter Property="IsTabStop" Value="false"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="contentPresenter" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3044FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DatePicker Style -->
        <Style x:Key="ElegantDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (Slightly Bluish) -->
            <Border Grid.Row="0" Background="#FFF2F6FF" Padding="30,25" BorderThickness="0,0,0,1" CornerRadius="20,20,0,0">
                <StackPanel>
                    <Grid>
                        <TextBlock x:Name="txtTitle" Text="Create New Loan" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                        <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnCancel_Click">
                            <fa:ImageAwesome Icon="Close" Width="14" Height="14" Foreground="#64748B"/>
                        </Button>
                    </Grid>
                    <TextBlock x:Name="txtSubtitle" Text="Enter the loan details below to proceed." FontSize="13" Foreground="#64748B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Form Fields (Main Content) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,25">
                <StackPanel>
                    <!-- Client Selection -->
                    <TextBlock Text="Select Client (Name or ID)" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbClient" Style="{StaticResource ElegantComboBox}" IsEditable="True" Margin="0,0,0,20" DisplayMemberPath="client_display" SelectedValuePath="client_id" SelectionChanged="cmbClient_SelectionChanged"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Loan Amount -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Loan Amount (₱)" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtAmount" Style="{StaticResource ModernInput}" Margin="0,0,0,20">
                                <TextBox.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <!-- Interest Rate -->
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Interest Rate (%)" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtInterestRate" Style="{StaticResource ModernInput}" Margin="0,0,0,20">
                                <TextBox.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <!-- Due Date -->
                    <TextBlock Text="Due Date" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                    <DatePicker x:Name="dtpDueDate" Style="{StaticResource ElegantDatePicker}" Margin="0,0,0,20"/>

                    <!-- Installment Plan -->
                    <TextBlock Text="Installment Plan" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbInstallmentPlan" Style="{StaticResource ElegantComboBox}" Margin="0,0,0,20">
                        <ComboBoxItem Content="Daily"/>
                        <ComboBoxItem Content="Semimonthly"/>
                        <ComboBoxItem Content="Monthly"/>
                        <ComboBoxItem Content="Quarterly"/>
                        <ComboBoxItem Content="Anually"/>
                    </ComboBox>

                    <!-- Status (Only for Update) -->
                    <StackPanel x:Name="statusPanel" Visibility="Collapsed">
                        <TextBlock Text="Loan Status" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cmbStatus" Style="{StaticResource ElegantComboBox}" Margin="0,0,0,20">
                            <ComboBoxItem Content="Active"/>
                            <ComboBoxItem Content="Paid"/>
                            <ComboBoxItem Content="Past Due"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer (Slightly Bluish) -->
            <Border Grid.Row="2" Background="#FFF2F6FF" Padding="30,20" BorderThickness="0,1,0,0" CornerRadius="0,0,20,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="Cancel" Grid.Column="0" Height="45" Margin="0,0,10,0" Background="White" Foreground="#64748B" BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand" Click="btnCancel_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnSave" Content="Save Loan" Grid.Column="1" Height="45" Background="#3044FF" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="btnSave_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
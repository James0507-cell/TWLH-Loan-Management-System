<Page x:Class="TWLH_Loan_Management_System.Employees"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:fa="http://schemas.fontawesome.io/icons/"
      Title="Employee Management" Height="700" Width="1000" Background="#F8F9FA">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Employee Management" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Manage team members and access control" Foreground="#6B7280" FontSize="14"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="+ Add Employee" Padding="15,8" 
                    Background="#4F46E5" Foreground="White" BorderThickness="0" Height="36" Click="Button_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </DockPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15,10" Margin="0,0,0,20"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <TextBlock Text="Search employees by name, email, or role..." Foreground="#9CA3AF" 
                           IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0"/>
                <TextBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="All Employees" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ListView x:Name="EmployeeListView" BorderThickness="0" Background="Transparent">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Employee" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <Ellipse Width="35" Height="35" Fill="#6366F1"/>
                                                <StackPanel Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                                                    <TextBlock Text="{Binding username}" Foreground="#6B7280" FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Role" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F3E8FF" CornerRadius="10" Padding="8,2">
                                                <TextBlock Text="{Binding Role}" Foreground="#7E22CE" FontSize="12" HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Email" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Email}" Foreground="#4B5563"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                
                                <GridViewColumn Header="Status" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#DCFCE7" CornerRadius="10" Padding="8,2">
                                                <TextBlock Text="{Binding Status}" Foreground="#15803D" FontSize="12"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Date Hired" DisplayMemberBinding="{Binding DateHired}" Width="120"/>

                                <GridViewColumn Header="Actions" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Edit" Click="BtnEdit_Click" Background="Transparent" BorderThickness="0" Foreground="#4F46E5" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                                <Button Content="Deactivate" Click="BtnDeactivate_Click" Background="Transparent" BorderThickness="0" Foreground="#EF4444" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="3" Columns="3" Margin="0,20,0,0">
            <Border Background="White" Margin="0,0,10,0" Padding="15" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <fa:ImageAwesome Icon="UserCircle" Foreground="#6366F1" Width="16" Height="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Admin" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBlock Text="Full system access and management." TextWrapping="Wrap" Foreground="#4B5563" FontSize="11"/>
                </StackPanel>
            </Border>

            <Border Background="White" Margin="5,0,5,0" Padding="15" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <fa:ImageAwesome Icon="UserCircle" Foreground="#10B981" Width="16" Height="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Staff" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBlock Text="Transaction and loan processing." TextWrapping="Wrap" Foreground="#4B5563" FontSize="11"/>
                </StackPanel>
            </Border>

            <Border Background="White" Margin="10,0,0,0" Padding="15" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <fa:ImageAwesome Icon="UserCircle" Foreground="#8B5CF6" Width="16" Height="16" Margin="0,0,10,0"/>
                        <TextBlock Text="Collector" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBlock Text="Assigned collections and follow-ups." TextWrapping="Wrap" Foreground="#4B5563" FontSize="11"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</Page>
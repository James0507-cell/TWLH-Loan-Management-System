<Page x:Class="TWLH_Loan_Management_System.PastDueAccountPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TWLH_Loan_Management_System"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="PastDueAccountPage" d:DesignHeight="650" d:DesignWidth="1100" Background="#FFF2F4F7" Loaded="Page_Loaded">
    <Page.Resources>
        <!-- Modern Search Box Style -->
        <Style x:Key="ModernSearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:ImageAwesome Icon="Search" Width="14" Height="14" Foreground="#A0AEC0" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,15,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Elegant ComboBox Style -->
        <Style x:Key="ElegantComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10"/>
                            <ToggleButton x:Name="toggleButton" BorderThickness="0" Background="Transparent" ClickMode="Press" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0 Z" Fill="#64748B" HorizontalAlignment="Right" Margin="0,0,12,0" VerticalAlignment="Center" Stretch="Uniform" Width="8"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentPresenter" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" IsHitTestVisible="false"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Grid.ColumnSpan="2" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{Binding ActualWidth, ElementName=border}" Margin="0,2,0,0">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="140"/>
            <RowDefinition Height="Auto" MinHeight="55"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="30,30,30,20">
            <TextBlock Text="Past Due Accounts" FontSize="26" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Monitor and manage accounts that have missed their installment payments." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
            <Separator Background="#E2E8F0" Height="1" Margin="0,15,0,0"/>
        </StackPanel>

        <!-- Unified Actions Bar -->
        <Grid Margin="30,0,30,0" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filters & Search -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <!-- Search -->
                <Grid Width="300">
                    <TextBox Style="{StaticResource ModernSearchBox}" x:Name="txtSearch" TextChanged="txtSearch_TextChanged"/>
                    <TextBlock IsHitTestVisible="False" Text="Search client or account ID..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0" Foreground="#A0AEC0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Status Filter -->
                <ComboBox Style="{StaticResource ElegantComboBox}" x:Name="cmbStatus" Width="180" Margin="15,0,0,0" SelectionChanged="cmbStatus_SelectionChanged">
                    <ComboBoxItem Content="All Statuses" IsSelected="True"/>
                    <ComboBoxItem Content="Open"/>
                    <ComboBoxItem Content="Promise to Pay"/>
                    <ComboBoxItem Content="Resolved"/>
                </ComboBox>
            </StackPanel>

            <!-- Layout Toggles -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="4" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnCardView" Click="btnCardView_Click" Padding="12,6" Background="#F1F5F9" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="ThLarge" Width="12" Height="12" Foreground="#3044FF"/>
                            <TextBlock Text="Cards" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="#3044FF"/>
                        </StackPanel>
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnTableView" Click="btnTableView_Click" Padding="12,6" Background="Transparent" BorderThickness="0" Margin="4,0,0,0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Table" Width="12" Height="12" Foreground="#64748B"/>
                            <TextBlock Text="Table" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="#64748B"/>
                        </StackPanel>
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <!-- Card Layout -->
            <ScrollViewer x:Name="scrollCards" Margin="30,20,30,20" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="pastDueContainer" ItemWidth="320" HorizontalAlignment="Center"/>
            </ScrollViewer>

            <!-- Table Layout (Hidden by default) -->
            <Frame x:Name="pastDueFrame" Visibility="Collapsed" NavigationUIVisibility="Hidden"/>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Margin="30,10,30,25">
            <Separator Background="#E2E8F0" Height="1" Margin="0,0,0,15"/>
            <TextBlock Text="© 2026 TWLH Loan Management System | System v1.0" 
                       HorizontalAlignment="Center" Foreground="#64748B" FontSize="11"/>
        </StackPanel>
    </Grid>
</Page>

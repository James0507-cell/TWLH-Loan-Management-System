<Page x:Class="TWLH_Loan_Management_System.CollectorDashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:fa="http://schemas.fontawesome.io/icons/"
      xmlns:local="clr-namespace:TWLH_Loan_Management_System"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="CollectorDashboard" Loaded="Page_Loaded">

    <Grid Background="#FFF2F4F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="30,20,0,10">
            <TextBlock TextWrapping="Wrap" Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="#333"/>
            <TextBlock TextWrapping="Wrap" Text="Welcome Back, Collection Agent" FontSize="12" Foreground="#FF989898"/>
            <Separator Background="#DDDDDD" Height="1" Margin="0,15,30,0"/>
        </StackPanel>

        <!-- Stats Cards Section -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="20,10">
            <!-- My Assignment Card -->
            <Border Margin="10" Background="White" CornerRadius="15" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1.5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <fa:ImageAwesome Icon="ListAlt" Width="24" Height="24" Foreground="#FF2196F3" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="My Assignments" FontSize="14" Foreground="#FF757575"/>
                        <TextBlock x:Name="txtMyAssignmentCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#333"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Overdue Assignment Card -->
            <Border Margin="10" Background="White" CornerRadius="15" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1.5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <fa:ImageAwesome Icon="ExclamationTriangle" Width="24" Height="24" Foreground="#FFF44336" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Overdue Assignments" FontSize="14" Foreground="#FF757575"/>
                        <TextBlock x:Name="txtOverdueCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#333"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- Assignment List Section -->
        <Grid Grid.Row="2" Margin="30,10,30,30">
            <Border Background="White" CornerRadius="15" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1.5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="My Assignments Details" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    <DataGrid x:Name="dgAssignments" Grid.Row="1"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              SelectionMode="Single"
                              RowHeight="60"
                              Background="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              FontSize="13"
                              CanUserAddRows="False"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <!-- Header Style -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="Padding" Value="15,12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            </Style>
                            <!-- Row Style -->
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <!-- Cell Style -->
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <!-- Client Info -->
                            <DataGridTemplateColumn Header="CLIENT" Width="2*" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="38" Height="38" Background="#EEF2FF" CornerRadius="19">
                                                <fa:ImageAwesome Icon="User" Foreground="#3044FF" Width="14" Height="14"/>
                                            </Border>
                                            <TextBlock Text="{Binding client_name}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Amount Due -->
                            <DataGridTextColumn Header="AMOUNT DUE" Binding="{Binding total_amount_to_pay, StringFormat=₱\{0:N2\}}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Due Date -->
                            <DataGridTextColumn Header="DUE DATE" Binding="{Binding due_date, StringFormat=\{0:MMM dd yyyy\}}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Status -->
                            <DataGridTemplateColumn Header="STATUS" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" CornerRadius="6" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding assignment_status}" Value="Overdue">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding assignment_status}" Value="In Progress">
                                                            <Setter Property="Background" Value="#E0E7FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding assignment_status}" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding assignment_status}" Value="Overdue">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding assignment_status}" Value="In Progress">
                                                                <Setter Property="Foreground" Value="#3044FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Actions -->
                            <DataGridTemplateColumn Header="ACTIONS" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Manage" Click="BtnManage_Click" Cursor="Hand" Background="#3044FF" Foreground="White" BorderThickness="0" Padding="12,6">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        <DockPanel LastChildFill="False"/>
    </Grid>
</Page>
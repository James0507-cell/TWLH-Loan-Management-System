<Page x:Class="TWLH_Loan_Management_System.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TWLH_Loan_Management_System"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="Page1" Background="#FFF0F2F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="22,20,22,0">
            <StackPanel>
                <TextBlock Text="Client Portfolio" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Manage clients and business information" Foreground="#64748B" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Search & Action Section -->
        <Grid Grid.Row="1" Margin="22,25,22,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Refined Search Bar -->
            <Border Grid.Column="0" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Margin="0,0,15,0">
                <Grid Margin="15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Path Grid.Column="0" 
                          Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                          Fill="#94A3B8" 
                          Stretch="Uniform" 
                          Width="18" 
                          Height="18"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"/>

                    <TextBox x:Name="txtSearch" Grid.Column="1" 
                             Tag="Search clients by name, ID or business..." 
                             BorderThickness="0" 
                             Background="Transparent"
                             Foreground="#1E293B"
                             VerticalAlignment="Center"
                             FontSize="14" 
                             TextChanged="TextBox_TextChanged"/>
                </Grid>
            </Border>

            <!-- Add Client Button moved here -->
            <Button x:Name="btnAddClient" Grid.Column="1" 
                    Content="+ Add New Client" 
                    Background="#6366F1"
                    Foreground="White"
                    Padding="20,0"
                    Height="44"
                    BorderThickness="0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Click="btnAddClient_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Content Section -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10,0,10,10">
            <WrapPanel x:Name="clientContainer" HorizontalAlignment="Center" Orientation="Horizontal">
                <!-- Client Cards will be loaded here -->
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>

<Window x:Class="TWLH_Loan_Management_System.installmentTransactionDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TWLH_Loan_Management_System"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="Transaction Details" Height="410" Width="450" WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <!-- Custom Card Button Style - if needed, copy from LoanDetails.xaml -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" BorderThickness="0" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>    <!-- Header -->
                <RowDefinition Height="*"/>       <!-- Main Content -->
                <RowDefinition Height="Auto"/>    <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Background="#FFF2F6FF" CornerRadius="20,20,0,0" Padding="20,25">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock x:Name="txtHeader" Text="Transaction Log" FontSize="20" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnClose_Click" Grid.Column="1" Margin="0,-5,0,0">
                        <fa:ImageAwesome Icon="Close" Width="14" Height="14" Foreground="#64748B"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10">
                <StackPanel x:Name="transactionContainer" Margin="20,10"/>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0" Background="#FFF2F6FF" CornerRadius="0,0,20,20" Padding="20,15">
                <Grid>
                    <TextBlock Text="TOTAL PAYMENT" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock x:Name="txtTotalPayment" Text="₱0.00" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="24" FontWeight="SemiBold" Foreground="#3044FF"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
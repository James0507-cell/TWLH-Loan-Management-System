<Window x:Class="TWLH_Loan_Management_System.UpdatePromisetopay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Promise Record" 
        Height="500" Width="450" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="20" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Direction="0" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Update Promise" FontSize="22" FontWeight="Bold" Foreground="#344767"/>
                <TextBlock x:Name="TxtPromiseID" Text="PROMISE #0000" FontSize="12" Foreground="#5E72E4" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Promise Amount (₱)" FontSize="12" Foreground="#8392AB" Margin="0,0,0,5"/>
                <Border BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,0,15">
                    <TextBox x:Name="TxtAmount" BorderThickness="0" FontSize="16" FontWeight="SemiBold" VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Text="Payment Date" FontSize="12" Foreground="#8392AB" Margin="0,0,0,5"/>
                <Border BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,0,15">
                    <DatePicker x:Name="DpDate" BorderThickness="0" VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Text="Admin Remarks" FontSize="12" Foreground="#8392AB" Margin="0,0,0,5"/>
                <Border BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="8" Padding="10,5">
                    <TextBox x:Name="TxtRemarks" BorderThickness="0" FontSize="13" Height="100" 
                             TextWrapping="Wrap" AcceptsReturn="True" Foreground="#67748E"/>
                </Border>
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="2" Margin="0,20,0,0">
                <Button x:Name="BtnCancel" Content="Cancel" Click="BtnCancel_Click"
                        Background="Transparent" Foreground="#8392AB" BorderThickness="0" Height="45" FontWeight="Bold" Cursor="Hand"/>

                <Button x:Name="BtnSave" Content="Save Changes" Click="BtnSave_Click"
                        Background="#5E72E4" Foreground="White" BorderThickness="0" Height="45" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
<Window x:Class="TWLH_Loan_Management_System.editEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Employee" 
        Height="620" Width="450" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="20" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Direction="0" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Edit Employee" FontSize="22" FontWeight="Bold" Foreground="#344767"/>
                <TextBlock x:Name="TxtEmployeeID" Text="EMPLOYEE #0000" FontSize="12" Foreground="#5E72E4" FontWeight="SemiBold"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="First Name" FontSize="12" Foreground="#8392AB" Margin="0,0,0,5"/>
                    <Border BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,0,15">
                        <TextBox x:Name="TxtFirstName" BorderThickness="0" FontSize="16" VerticalContentAlignment="Center" Foreground="#67748E"/>
                    </Border>

                    <TextBlock Text="Middle Name" FontSize="12" Foreground="#8392AB" Margin="0,0,0,5"/>
                    <Border BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,0,15">
                        <TextBox x:Name="TxtMiddleName" BorderThickness="0" FontSize="16" VerticalContentAlignment="Center" Foreground="#67748E"/>
                    </Border>

                    <TextBlock Text="Last Name" FontSize="12" Foreground="#8392AB" Margin="0,0,0,5"/>
                    <Border BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,0,15">
                        <TextBox x:Name="TxtLastName" BorderThickness="0" FontSize="16" VerticalContentAlignment="Center" Foreground="#67748E"/>
                    </Border>

                    <TextBlock Text="Designated Role" FontSize="12" Foreground="#8392AB" Margin="0,0,0,5"/>
                    <Border BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,0,15">
                        <ComboBox x:Name="CbRole" BorderThickness="0" VerticalContentAlignment="Center" Background="Transparent">
                            <ComboBoxItem Content="Admin"/>
                            <ComboBoxItem Content="Staff"/>
                            <ComboBoxItem Content="Collector"/>
                        </ComboBox>
                    </Border>

                    <TextBlock Text="Account Status" FontSize="12" Foreground="#8392AB" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock x:Name="TxtStatus" Text="ACTIVE" FontWeight="Bold" Foreground="#2DCE89" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <UniformGrid Grid.Row="2" Columns="2" Margin="0,20,0,0">
                <Button x:Name="BtnCancel" Content="Cancel" Click="BtnCancel_Click"
                        Background="Transparent" Foreground="#8392AB" BorderThickness="0" Height="45" FontWeight="Bold" Cursor="Hand"/>

                <Button x:Name="BtnSave" Content="Save Changes" Click="BtnSave_Click"
                        Background="#5E72E4" Foreground="White" BorderThickness="0" Height="45" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</Window>